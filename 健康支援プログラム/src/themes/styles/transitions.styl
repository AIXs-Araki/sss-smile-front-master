/* -------------------------------------
 *	vue-transition css
 * ------------------------------------- */
.fade-enter-active
.fade-leave-active
.slide-right-enter-active
.slide-right-leave-active
.slide-left-enter-active
.slide-left-leave-active
.slide-top-enter-active
.slide-top-leave-active
.slide-bottom-enter-active
.slide-bottom-leave-active
	transition all .3s ease
.fade-enter
.fade-leave-active
	opacity 0
	transform translate3d(0, 0, 0)
.slide-top-enter
.slide-top-leave-active
	transform translate3d(0, -16px, 0)
	opacity 0
.slide-right-enter
	transform translate3d(-16px, 0, 0)
	opacity 0
.slide-right-leave-active
	transform translate3d(16px, 0, 0)
	opacity 0
.slide-bottom-enter
.slide-bottom-leave-active
	transform translate3d(0, 16px, 0)
	opacity 0
.slide-left-enter
	transform translate3d(60px, 0, 0)
	opacity 0
.slide-left-leave-active
	transform translate3d(60px, 0, 0)
	opacity 0


.slide-bottomLong-enter-active
.slide-bottomLong-leave-active
	transition all .4s ease
.slide-bottomLong-enter
.slide-bottomLong-leave-active
	transform translate3d(0, 100vh, 0)

/* -------------------------------------
 *	vue-transition css
 * ------------------------------------- */
.slide-topdown-enter-active
.slide-topdown-leave-active
	transition all .3s ease
.slide-topdown-enter
	transform translate3d(0, -16px, 0)
	opacity 0
.slide-topdown-leave-active
	transform translate3d(0, 16px, 0)
	opacity 0

.slide-leftdown-enter-active
.slide-leftdown-leave-active
	transition all .3s ease
.slide-leftdown-enter
.slide-leftdown-leave-active
	transform-origin 80% 100%
	transform translate3d(0, 32px, 0) rotate(-8deg)
	opacity 0

.fade-scaleOut-enter-active
.fade-scaleOut-leave-active
	transition all .4s ease
.fade-scaleOut-enter
.fade-scaleOut-leave-active
	transform scale(1.1)
	opacity 0
.fade-scaleIn-enter-active
.fade-scaleIn-leave-active
	transition all .4s ease
.fade-scaleIn-enter
.fade-scaleIn-leave-active
	transform scale(.97)
	opacity 0
