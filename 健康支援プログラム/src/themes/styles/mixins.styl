/* -------------------------------------
 *	transition css
 * ------------------------------------- */
@import "./transitions.styl"

// colors
// ==================
text-color = #333 //rgb(12,27,58)
text-deep = rgb(31,31,31)
text-light = #666
// bg-color = rgb(12,27,58) // #0c1b3a
bg-color = white//rgb(255,255,255) //rgb(13,15,37) // #0d0f25
main-color = #333 //rgb(12,27,58) // #36c0ca
a-color = rgb(23,29,61) // #171d3d
red-color = #e74c3c
turquoise-color = #1abc9c
blue-color = rgb(9,109,242)
purple-color = rgb(101,33,234) // #6521ea
purple-deep = rgb(70,27,160) // #461ba0
sub-color = rgb(245,80,89) // #f55059
line-color = rgb(227,228,229)
pre-color = #f5f6f7// #fbfaf8
pre-hover = #e9eaeb
pre-border = #dfe6ec // #e5e4e3
pre-deep = #bfc9d9 //rgb(191, 201, 217)
gray-color = #999999
gray-light = #e5e5e5

// colors > alpha
// ==================
bgrgba(val)
	rgba(247,248,249,val)
	// rgba(5,8,15,val)
	// rgba(12,27,58,val)
mrgba(val)
	rgba(51,51,51,val)//rgba(12,27,58,val)
wrgba(val)
	rgba(255,255,255,val)
brgba(val)
	rgba(0,0,0,val)

// transition
// ==================
transition(val)
	transition all val cubic-bezier(0.25, 0.1, 0.2, 1)
	-webkit-transition all val cubic-bezier(0.25, 0.1, 0.2, 1)

// fonts
// ==================
.source-serif
	font-family -apple-system, 'Source Sans Pro', helvetica, meiryo, sans-serif
.open-serif
	font-family -apple-system, 'Open Sans', helvetica, meiryo, sans-serif
.source-serif-i
	font-family 'Source Sans Pro', helvetica, meiryo, sans-serif
.open-serif-i
	font-family 'Open Sans', helvetica, meiryo, sans-serif
.noto-serif-i
	font-family 'Noto Sans', helvetica, meiryo, sans-serif
.lob-serif-i
	font-family 'Lobster', helvetica, meiryo, sans-serif

// placeholder
// ==================
::-webkit-input-placeholder
	color brgba(.3) !important
:-moz-placeholder
::-moz-placeholder
	color brgba(.3) !important
	opacity 1 !important

// rumble > keyframe animation
// ==================
@keyframes anim-rumble {
	0% {
		transform rotate(0deg) translate(0,0)
	}
	12.5% {
		transform rotate(0.4deg) translate(2px,-2px)
	}
	25% {
		transform rotate(0.8deg) translate(0px,2px)
	}
	37.5% {
		transform rotate(0.4deg) translate(-2px,0)
	}
	50%	{
		transform rotate(0deg) translate(0,0)
	}
	62.5% {
		transform rotate(-0.4deg) translate(2px,0)
	}
	75%	{
		transform rotate(-0.8deg) translate(0,2px)
	}
	87.5% {
		transform rotate(-0.4deg) translate(-2px,-2px)
	}
	100% {
		transform rotate(0deg) translate(0,0)
	}
}
